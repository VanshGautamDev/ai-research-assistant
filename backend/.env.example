# --- App ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- LLM Provider: "ollama" (free/local, default) | "openai" | "gemini" ---
LLM_PROVIDER=ollama

# Ollama (free, runs on your machine — install from https://ollama.com,
# then run: ollama pull llama3.2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2

# Only needed if you switch LLM_PROVIDER to a paid hosted option:
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.5-pro

# --- Embeddings: free local model, downloads once, no API key ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- RAG tuning ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=6

# --- CORS: comma-separated origins parsed by pydantic-settings as a list ---
CORS_ORIGINS=["http://localhost:3000"]

MAX_UPLOAD_MB=50
